      "title": "Ketone ester supplementation blunts overreaching symptoms during endurance training overload",
      "year": 2019,
      "openAccessPdf": {
        "url": "https://physoc.onlinelibrary.wiley.com/doi/pdfdirect/10.1113/JP277831",
        "status": "HYBRID",
        "license": "CCBY",
